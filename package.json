{
  "name": "mailer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:cf": "node scripts/patch-opennext-win.cjs && prisma generate --no-engine && opennextjs-cloudflare build && node scripts/patch-prisma-cf.cjs && node scripts/patch-worker-cron.cjs",
    "deploy:cf": "npm run build:cf && wrangler deploy",
    "deploy": "npm run deploy:cf",
    "db:migrate": "prisma migrate deploy",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.26.0",
    "next": "16.2.11",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.3",
    "radix-ui": "^1.6.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.10.0",
    "shadcn": "^4.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@opennextjs/cloudflare": "^1.20.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.113.0"
  }
}
